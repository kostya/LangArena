FROM benchmarks:rust

ARG nodeversion
RUN curl -fsSL https://deb.nodesource.com/setup_$nodeversion | bash - \
    && apt install -y --no-install-recommends nodejs \
    && apt clean

RUN curl https://get.wasmer.io -sSfL | sh

RUN curl -sSf https://raw.githubusercontent.com/WasmEdge/WasmEdge/master/utils/install.sh | bash

ENV PATH=/root/.wasmer/bin:$PATH
ENV PATH=/root/.wasmedge/bin:$PATH
ENV PATH=/root/.wasmtime/bin:$PATH

RUN rustup target add wasm32-wasip1

# RUN cargo install wasm-opt --locked
RUN apt install -y --no-install-recommends binaryen \
    && apt clean

RUN curl https://wasmtime.dev/install.sh -sSf | bash
