FROM ubuntu:24.04

WORKDIR /opt
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# ============================================
# Обновление системы и базовые пакеты
# ============================================
RUN apt-get update && apt-get install -y \
    software-properties-common \
    wget \
    curl \
    git \
    gnupg \
    libgmp-dev \
    build-essential \
    iputils-ping \
    ca-certificates \
    time

RUN apt install -y vim mc # for debug
